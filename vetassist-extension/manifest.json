{
  "manifest_version": 3,
  "name": "VetAssist Loader",
  "version": "0.1.0",
  "description": "Loads licensed VetAssist tools into AIRS.",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://airsso.vet.minpolj.gov.rs/*",
    "https://vetasist-app.vercel.app/*"
  ],
  "action": {
    "default_title": "VetAssist",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "sw.js"
  },
  "content_scripts": [
    {
      "matches": ["https://airsso.vet.minpolj.gov.rs/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}